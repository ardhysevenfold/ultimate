import base64,os,sys
from Crypto.Cipher import AES

def d(x,_oytmxiiskxnvvpr):
    raw = base64.b64decode(x)
    nonce = raw[:12]
    tag = raw[12:28]
    ct = raw[28:]
    cipher = AES.new(_oytmxiiskxnvvpr, AES.MODE_GCM, nonce=nonce)
    return cipher.decrypt_and_verify(ct, tag)

def u(t):
    base="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/="
    kh=0x1780
    ar=0x0600
    o=""
    for c in t:
        o2=ord(c)
        if kh<=o2<kh+len(base):
            o+=base[o2-kh]
        elif ar<=o2<ar+len(base):
            o+=base[o2-ar]
        else:
            o+=c
    return o

