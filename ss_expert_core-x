def ង(s):
    bc="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/="
    kb=0x1780
    o=[]
    for c in s:
        i=ord(c)-kb
        if i<0 or i>=len(bc):
            return ""
        o.append(bc[i])
    return "".join(o)

